PORT=4000
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CACHE_TTL_SECONDS=900
STALE_CACHE_TTL_SECONDS=21600
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
REQUEST_TIMEOUT_MS=8000
EMBED_GATEWAY_BASE_URL=https://your-worker.workers.dev
EMBED_GATEWAY_SECRET=replace_with_the_same_secret_used_by_worker
EMBED_TOKEN_TTL_SECONDS=900
EMBED_PROVIDER=
EMBED_PROVIDERS=env-2
EMBED_PROVIDER_SELECTION=best-health
EMBED_PROVIDER_BLACKLIST=env-1,env-3,env-4,env-5,env-6,env-7,env-8,env-9,env-10
CUSTOM_EMBED_NAME=
CUSTOM_EMBED_BASE_URL=
CUSTOM_EMBED_MOVIE_PATTERN=/movie/{tmdb_id}
CUSTOM_EMBED_TV_PATTERN=/tv/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_1_NAME=2Embed
AUTHORIZED_EMBED_PROVIDER_1_BASE_URL=https://2embed.to
AUTHORIZED_EMBED_PROVIDER_1_MOVIE_PATTERN=/embed/tmdb/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_1_TV_PATTERN=/embed/tmdb/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_2_NAME=VidLink
AUTHORIZED_EMBED_PROVIDER_2_BASE_URL=https://vidlink.pro
AUTHORIZED_EMBED_PROVIDER_2_MOVIE_PATTERN=/movie/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_2_TV_PATTERN=/tv/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_2_QUERY_PARAMS=autoplay=false&player=default&title=true&poster=true
AUTHORIZED_EMBED_PROVIDER_3_NAME=VidSrcMe.su
AUTHORIZED_EMBED_PROVIDER_3_BASE_URL=https://vidsrc.me
AUTHORIZED_EMBED_PROVIDER_3_MOVIE_PATTERN=/embed/tmdb/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_3_TV_PATTERN=/embed/tmdb/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_4_NAME=VSEmbed.ru
AUTHORIZED_EMBED_PROVIDER_4_BASE_URL=https://vsemembed.ru
AUTHORIZED_EMBED_PROVIDER_4_MOVIE_PATTERN=/embed/tmdb/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_4_TV_PATTERN=/embed/tmdb/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_5_NAME=VidSrc-Embed.ru
AUTHORIZED_EMBED_PROVIDER_5_BASE_URL=https://vidsrc-embed.ru
AUTHORIZED_EMBED_PROVIDER_5_MOVIE_PATTERN=/embed/tmdb/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_5_TV_PATTERN=/embed/tmdb/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_6_NAME=VidSrc-Embed.su
AUTHORIZED_EMBED_PROVIDER_6_BASE_URL=https://vidsrc-embed.su
AUTHORIZED_EMBED_PROVIDER_6_MOVIE_PATTERN=/embed/tmdb/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_6_TV_PATTERN=/embed/tmdb/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_7_NAME=vsrc.su
AUTHORIZED_EMBED_PROVIDER_7_BASE_URL=https://vsrc.su
AUTHORIZED_EMBED_PROVIDER_7_MOVIE_PATTERN=/embed/tmdb/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_7_TV_PATTERN=/embed/tmdb/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_8_NAME=NontonGo
AUTHORIZED_EMBED_PROVIDER_8_BASE_URL=https://nontongo.com
AUTHORIZED_EMBED_PROVIDER_8_MOVIE_PATTERN=/embed/tmdb/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_8_TV_PATTERN=/embed/tmdb/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_9_NAME=VidSrc.cc
AUTHORIZED_EMBED_PROVIDER_9_BASE_URL=https://vidsrc.cc/v2
AUTHORIZED_EMBED_PROVIDER_9_MOVIE_PATTERN=/embed/movie/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_9_TV_PATTERN=/embed/tv/{tmdb_id}/{season}/{episode}
AUTHORIZED_EMBED_PROVIDER_10_NAME=VidSrc.cc v3
AUTHORIZED_EMBED_PROVIDER_10_BASE_URL=https://vidsrc.cc/v3
AUTHORIZED_EMBED_PROVIDER_10_MOVIE_PATTERN=/embed/movie/{tmdb_id}
AUTHORIZED_EMBED_PROVIDER_10_TV_PATTERN=/embed/tv/{tmdb_id}/{season}/{episode}
